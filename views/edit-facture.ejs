<!DOCTYPE html>
<html>

<head>

    <title>Edit Facture</title>

    <link rel="stylesheet" href="/style.css">

</head>

<body>

<div class="content">

    <h1>Edit Facture</h1>
    <a href="/logout">
    Logout
</a>

    <form method="POST"
    action="/update-facture/<%= facture.id %>">

        <input type="text"
        name="client"
        value="<%= facture.client %>">

        <input type="number"
        name="montant"
        value="<%= facture.montant %>">

        <input type="date"
        name="date_facture"
        value="<%= facture.date_facture %>">

        <button type="submit">
            Update
        </button>

    </form>

</div>

</body>
</html>
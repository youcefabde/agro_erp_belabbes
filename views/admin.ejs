<!DOCTYPE html>
<html>

<head>

    <title>Admin Dashboard</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/output.css">

</head>

<body class="bg-gray-100">

  <div class="p-10">

    <h1 class="text-4xl font-bold text-green-700 mb-8">
      Agro ERP Dashboard
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="bg-white p-6 rounded-2xl shadow">
        <h2 class="text-gray-500">Clients</h2>
        <p class="text-3xl font-bold"><%= totalClients %></p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h2 class="text-gray-500">Produits</h2>
        <p class="text-3xl font-bold"><%= totalProduits %></p>
      </div>

      <div class="bg-white p-6 rounded-2xl shadow">
        <h2 class="text-gray-500">Factures</h2>
        <p class="text-3xl font-bold"><%= totalFactures %></p>
      </div>

    </div>

  </div>

</body>


</html>